# =============================================================================
# Kinship EHR — Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in your development credentials.
# NEVER commit real credentials. All .env* files are git-ignored except this one.
#
# Three separate Supabase projects are required:
#   1. Development  — local development (.env.local)
#   2. Staging      — Vercel Preview environment (set in Vercel dashboard)
#   3. Production   — Vercel Production environment (set in Vercel dashboard)
#
# See ENVIRONMENTS.md for full setup instructions.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — replace with your environment's project credentials
# Supabase Dashboard → Project → Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# -----------------------------------------------------------------------------
# Clerk — Authentication
# clerk.com → Dashboard → API Keys
# Use test keys (pk_test_/sk_test_) for dev/staging, live keys for production.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# -----------------------------------------------------------------------------
# Resend — Transactional email  (optional for dev)
# resend.com → API Keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_your_key_here

# -----------------------------------------------------------------------------
# Twilio — SMS reminders  (optional for dev)
# console.twilio.com
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=ACyour_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# -----------------------------------------------------------------------------
# Office Ally — EDI clearinghouse  (optional for dev)
# -----------------------------------------------------------------------------
OFFICE_ALLY_USERNAME=your_username
OFFICE_ALLY_PASSWORD=your_password

# -----------------------------------------------------------------------------
# OCR.space — Document text extraction  (optional)
# Free tier: 25,000 requests/month — https://ocr.space/ocrapi
# Used to extract text from uploaded images and scanned PDFs (ID cards,
# insurance cards, referral forms, lab results, etc.)
# -----------------------------------------------------------------------------
OCR_SPACE_API_KEY=your_ocr_space_api_key_here
